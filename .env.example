# HYROX Rankings Analyzer 환경 설정 파일
# .env 파일로 이름을 바꿔서 사용하세요

# Flask 설정
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Hyrox 웹사이트
HYROX_BASE_URL=https://results.hyrox.com

# 캐시 설정 (초)
CACHE_TIMEOUT=3600

# API 레이트 제한
RATE_LIMIT_ENABLED=False
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# 데이터베이스 (향후 사용)
# DATABASE_URL=sqlite:///hyrox_data.db

# 로깅
LOG_LEVEL=INFO
LOG_FILE=hyrox_app.log

# CORS 설정
CORS_ORIGINS=*
